{
  "name": "nexatune",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter ui-react dev\" \"pnpm --filter desktop-electron dev\"",
    "build": "pnpm --filter shared-types build && pnpm --filter ui-react build && pnpm --filter desktop-electron build",
    "package": "pnpm --filter desktop-electron package",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
